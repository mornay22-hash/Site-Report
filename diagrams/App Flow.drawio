    <!-- IndexedDB -->
    <mxCell id="12" value="&lt;b&gt;IndexedDB (idb) — Sole Data Store&lt;/b&gt;&lt;br&gt;stores: reports · sections · photos · photo_blobs · meta&lt;br&gt;All reads/writes are local — zero network needed" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
